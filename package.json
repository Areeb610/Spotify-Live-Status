{
  "name": "spotify-live-status",
  "version": "1.0.0",
  "description": "Discord Rich Presence for Spotify with live lyrics",
  "main": "dist/main.js",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc && electron .",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.0.15",
    "axios": "^1.3.4",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/ws": "^8.5.4",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.3"
  },
  "build": {
    "appId": "com.spotify-live-status",
    "productName": "Spotify Live Status",
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/tray.png",
      "forceCodeSigning": false
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/tray.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/tray.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true
    }
  }
}
